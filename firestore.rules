rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: patients
    // Document ID: {patientId}
    // Fields:
    //   - name: string (required)
    //   - age: number (required)
    //   - gender: string (optional)
    //   - location: string (required)
    //   - symptoms: string (required)
    //   - diagnosis: string (optional)
    //   - malnutritionStatus: string (optional)
    //   - timestamp: timestamp (required)
    //   - volunteerId: string (required)
    //
    // Collection: alerts
    // Document ID: {alertId}
    // Fields:
    //   - type: string (required)
    //   - location: string (required)
    //   - severity: string (required)
    //   - description: string (optional)
    //   - timestamp: timestamp (required)
    //
    // Collection: volunteers
    // Document ID: {volunteerId}
    // Fields:
    //   - name: string (required)
    //   - email: string (required)
    //   - district: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/volunteers/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "pharmjoe7@gmail.com");
    }

    function isValidPatient(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.age is number && data.age >= 0 && data.age < 150 &&
             data.location is string && data.location.size() > 0 &&
             data.symptoms is string && data.symptoms.size() > 0 &&
             data.volunteerId == request.auth.uid &&
             data.timestamp is timestamp;
    }

    function isValidAlert(data) {
      return data.type is string && data.location is string &&
             data.severity in ['low', 'medium', 'high', 'critical'] &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /patients/{patientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPatient(request.resource.data);
      allow update: if isAuthenticated() && isValidPatient(request.resource.data) && 
                      (request.resource.data.volunteerId == resource.data.volunteerId || isAdmin());
      allow delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /volunteers/{volunteerId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(volunteerId);
      allow delete: if isAdmin();
    }
  }
}
